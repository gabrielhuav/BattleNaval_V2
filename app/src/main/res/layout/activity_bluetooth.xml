<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Bluetooth Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnStartServer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciar Servidor"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnConnectToDevice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conectar a Dispositivo"
                android:layout_marginEnd="8dp" />

        </LinearLayout>

        <!-- Bluetooth Status -->
        <TextView
            android:id="@+id/tvBluetoothStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Estado: Desconectado"
            android:textSize="16sp"
            android:textColor="@android:color/black" />

        <!-- Boards for Player and Enemy -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tu Tablero"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:textSize="18sp" />

        <FrameLayout
            android:id="@+id/playerBoardFrame"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tablero del Enemigo"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:textSize="18sp" />

        <FrameLayout
            android:id="@+id/enemyBoardFrame"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="16dp" />

        <!-- Special Round Panel -->
        <LinearLayout
            android:id="@+id/specialRoundPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvBinaryCoordinates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Coordenadas reveladas en binario: - (A1)"
                android:textSize="16sp"
                android:textColor="@android:color/black"
                android:layout_marginBottom="8dp" />
        </LinearLayout>

        <!-- Input Coordinates to Attack -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ingresa las Coordenadas para Atacar"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etAttackCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ejemplo: A5"
            android:inputType="text" />

        <Button
            android:id="@+id/btnSendAttack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enviar Coordenadas"
            android:layout_marginTop="8dp" />

        <!-- Dynamic Coordinates Display -->
        <TextView
            android:id="@+id/tvRevealedCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Respuesta revelada al Enemigo: -"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvEnemyShipCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Coordenadas del Barco Enemigo: -"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnBackToMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Volver al Menú"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>